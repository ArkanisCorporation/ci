{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-lint-github-actions/v1/schema.json",
  "title": "wf-lint-github-actions inputs",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "runs-on": {
      "type": "string",
      "default": "ubuntu-latest"
    },
    "runs-on-json": {
      "type": "string",
      "default": ""
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "enable-cache": {
      "type": "boolean",
      "description": "Enable the actionlint binary cache used by raven-actions/actionlint.",
      "default": true
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 10,
      "minimum": 1
    }
  }
}
