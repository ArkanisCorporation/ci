{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-setup-dotnet-generated-code/v1/schema.json",
  "title": "wf-setup-dotnet-generated-code inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "solution",
    "commands",
    "generated-paths"
  ],
  "properties": {
    "runs-on-json": {
      "type": "string",
      "default": "[\"ubuntu-latest\"]"
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "dotnet-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "solution": {
      "type": "string"
    },
    "configuration": {
      "type": "string",
      "default": "Release"
    },
    "restore-locked-mode": {
      "type": "boolean",
      "default": true
    },
    "enable-cache": {
      "type": "boolean",
      "default": true
    },
    "build-before-commands": {
      "type": "boolean",
      "default": true
    },
    "commands": {
      "type": "string"
    },
    "generated-paths": {
      "type": "string"
    },
    "run-commands-in-parallel": {
      "type": "boolean",
      "default": true
    },
    "fail-on-diff": {
      "type": "boolean",
      "default": true
    },
    "remediation-message": {
      "type": "string",
      "default": "Regenerate generated source locally and commit the resulting changes."
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 20,
      "minimum": 1
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 14,
      "minimum": 1,
      "maximum": 90
    }
  }
}
