{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-verify-deploy-k8s-aspire/v2/schema.json",
  "title": "wf-verify-deploy-k8s-aspire inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "aspire-environment",
    "kubernetes-namespace",
    "apphost-project"
  ],
  "properties": {
    "runs-on": {
      "type": "string",
      "default": "ubuntu-latest"
    },
    "runs-on-json": {
      "type": "string",
      "default": ""
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "aspire-environment": {
      "type": "string"
    },
    "kubernetes-namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "apphost-project": {
      "type": "string"
    },
    "output-path": {
      "type": "string",
      "default": "artifacts/k8s"
    },
    "image-tag": {
      "type": "string",
      "default": ""
    },
    "dotnet-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "enable-cache": {
      "type": "boolean",
      "default": true
    },
    "kubectl-version": {
      "type": "string",
      "default": "v1.36.2"
    },
    "helm-version": {
      "type": "string",
      "default": "v4.2.2"
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 45,
      "minimum": 1
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 30,
      "minimum": 1,
      "maximum": 90
    }
  }
}
