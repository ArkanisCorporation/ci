{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-verify-publish-container-dotnet/v1/schema.json",
  "title": "wf-verify-publish-container-dotnet inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "image",
    "version"
  ],
  "properties": {
    "runs-on": {
      "type": "string",
      "default": "ubuntu-latest"
    },
    "runs-on-json": {
      "type": "string",
      "default": ""
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "image": {
      "type": "string"
    },
    "context": {
      "type": "string",
      "default": "."
    },
    "dockerfile": {
      "type": "string",
      "default": "Dockerfile"
    },
    "platforms": {
      "type": "string",
      "default": "linux/amd64"
    },
    "version": {
      "type": "string",
      "description": "Bare semantic version without leading v."
    },
    "version-tag": {
      "type": "string",
      "default": ""
    },
    "version-channel": {
      "type": "string",
      "default": ""
    },
    "channel-latest": {
      "type": "boolean",
      "default": true
    },
    "extra-tags": {
      "type": "string",
      "default": ""
    },
    "buildkit-endpoint": {
      "type": "string",
      "default": ""
    },
    "build-args": {
      "type": "string",
      "default": ""
    },
    "sdk-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "version-working-directory": {
      "type": "string",
      "default": "."
    },
    "version-recursive": {
      "type": "boolean",
      "default": true
    },
    "version-project": {
      "type": "string",
      "default": ""
    },
    "version-tool-version": {
      "type": "string",
      "default": "4.0.0"
    },
    "cache-from": {
      "type": "string",
      "default": ""
    },
    "cache-to": {
      "type": "string",
      "default": ""
    },
    "labels": {
      "type": "string",
      "default": ""
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 45,
      "minimum": 1
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 30,
      "minimum": 1,
      "maximum": 90
    }
  }
}
