{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-setup-dotnet-jetbrains/v1/schema.json",
  "title": "wf-setup-dotnet-jetbrains inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "solution"
  ],
  "properties": {
    "runs-on-json": {
      "type": "string",
      "default": "[\"ubuntu-latest\"]"
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "dotnet-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "solution": {
      "type": "string"
    },
    "working-directory": {
      "type": "string",
      "default": "."
    },
    "restore-locked-mode": {
      "type": "boolean",
      "default": true
    },
    "enable-cache": {
      "type": "boolean",
      "default": true
    },
    "profile": {
      "type": "string",
      "default": "Built-in: Reformat & Apply Syntax Style"
    },
    "include": {
      "type": "string",
      "default": ""
    },
    "exclude": {
      "type": "string",
      "default": "**/*.razor;**/*.svg;**/*.md"
    },
    "no-updates": {
      "type": "boolean",
      "default": true
    },
    "restore-tools": {
      "type": "boolean",
      "default": true
    },
    "install-tool": {
      "type": "boolean",
      "default": false
    },
    "tool-version": {
      "type": "string",
      "default": ""
    },
    "fail-on-diff": {
      "type": "boolean",
      "default": true
    },
    "remediation-message": {
      "type": "string",
      "default": "Run `dotnet husky run --name dotnet-cleanupcode` locally and commit the resulting changes."
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 15,
      "minimum": 1
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 14,
      "minimum": 1,
      "maximum": 90
    }
  }
}
