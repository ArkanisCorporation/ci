{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-dotnet-format/v1/schema.json",
  "title": "wf-dotnet-format inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "solution"
  ],
  "properties": {
    "runs-on": {
      "type": "string",
      "default": "ubuntu-latest"
    },
    "runs-on-json": {
      "type": "string",
      "default": ""
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "dotnet-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "solution": {
      "type": "string"
    },
    "restore-locked-mode": {
      "type": "boolean",
      "default": true
    },
    "enable-cache": {
      "type": "boolean",
      "default": true
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 14,
      "minimum": 1,
      "maximum": 90
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 20,
      "minimum": 1
    }
  }
}
