{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-publish-nuget/v1/schema.json",
  "title": "wf-publish-nuget inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "version"
  ],
  "properties": {
    "runs-on-json": {
      "type": "string",
      "default": "[\"ubuntu-latest\"]"
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "environment-name": {
      "type": "string",
      "default": "nuget"
    },
    "project": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "dotnet-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "configuration": {
      "type": "string",
      "default": "Release"
    },
    "enable-cache": {
      "type": "boolean",
      "default": true
    },
    "source": {
      "type": "string",
      "default": "https://api.nuget.org/v3/index.json"
    },
    "trusted-publishing": {
      "type": "boolean",
      "default": true
    },
    "nuget-user": {
      "type": "string",
      "default": ""
    },
    "skip-duplicate": {
      "type": "boolean",
      "default": true
    },
    "include-symbols": {
      "type": "boolean",
      "default": true
    },
    "include-source": {
      "type": "boolean",
      "default": true
    },
    "dotnet-setversion": {
      "type": "boolean",
      "default": true
    },
    "dotnet-setversion-working-directory": {
      "type": "string",
      "default": "."
    },
    "dotnet-setversion-recursive": {
      "type": "boolean",
      "default": true
    },
    "dotnet-setversion-project": {
      "type": "string",
      "default": ""
    },
    "dotnet-setversion-tool-version": {
      "type": "string",
      "default": "4.0.0"
    },
    "dry-run": {
      "type": "boolean",
      "default": false
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 30,
      "minimum": 1
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 30,
      "minimum": 1,
      "maximum": 90
    }
  }
}
