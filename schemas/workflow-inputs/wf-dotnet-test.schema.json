{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkanis.dev/schemas/workflow-inputs/wf-dotnet-test/v1/schema.json",
  "title": "wf-dotnet-test inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "solution"
  ],
  "properties": {
    "runs-on": {
      "type": "string",
      "default": "ubuntu-latest"
    },
    "runs-on-json": {
      "type": "string",
      "default": ""
    },
    "runs-on-self-hosted": {
      "type": "boolean",
      "default": false
    },
    "dotnet-version": {
      "type": "string",
      "default": "10.0.x"
    },
    "global-json-file": {
      "type": "string",
      "default": ""
    },
    "solution": {
      "type": "string"
    },
    "configuration": {
      "type": "string",
      "default": "Release"
    },
    "restore-locked-mode": {
      "type": "boolean",
      "default": true
    },
    "enable-cache": {
      "type": "boolean",
      "default": true
    },
    "test-filter": {
      "type": "string",
      "default": ""
    },
    "coverage": {
      "type": "boolean",
      "default": true
    },
    "coverage-report": {
      "type": "boolean",
      "default": true
    },
    "coverage-pr-comment": {
      "type": "boolean",
      "default": true
    },
    "upload-test-results": {
      "type": "boolean",
      "default": false
    },
    "upload-coverage": {
      "type": "boolean",
      "default": false
    },
    "coverage-reporttypes": {
      "type": "string",
      "default": "HtmlInline;Cobertura;MarkdownSummaryGithub;TextSummary"
    },
    "coverage-assemblyfilters": {
      "type": "string",
      "default": "+*;-*.UnitTests;-*.IntegrationTests"
    },
    "coverage-report-custom-settings": {
      "type": "string",
      "default": ""
    },
    "coverage-report-tool-version": {
      "type": "string",
      "default": "5.5.10"
    },
    "artifact-retention-days": {
      "type": "integer",
      "default": 7,
      "minimum": 1,
      "maximum": 90
    },
    "timeout-minutes": {
      "type": "integer",
      "default": 30,
      "minimum": 1
    }
  }
}
